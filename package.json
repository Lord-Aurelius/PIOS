{
  "name": "pios",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:generate": "pnpm --filter @pios/database prisma:generate",
    "db:migrate": "pnpm --filter @pios/database prisma:migrate",
    "db:seed": "pnpm --filter @pios/database seed"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
