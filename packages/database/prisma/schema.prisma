generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum GeoLevel {
  COUNTRY
  COUNTY
  CONSTITUENCY
  WARD
  VILLAGE
  POLLING_STATION
}

enum FieldReportType {
  HOUSEHOLD_VISIT
  RALLY_ATTENDANCE
  COMMUNITY_ISSUE
  OPPOSITION_ACTIVITY
  SECURITY_INCIDENT
  DOOR_TO_DOOR
  POLLING_STATION
  VOLUNTEER_FEEDBACK
}

enum SentimentLabel {
  POSITIVE
  NEUTRAL
  NEGATIVE
  MIXED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum InsightType {
  RECOMMENDATION
  RISK
  BRIEFING
  FORECAST
  NARRATIVE
  MOBILIZATION
}

enum ContactType {
  SUPPORTER
  DONOR
  VOLUNTEER
  INFLUENCER
  LOCAL_LEADER
  MEDIA_CONTACT
  ORGANIZER
}

model Tenant {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  country     String
  brand       Json
  aiConfig    Json          @default("{}")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  users       User[]
  campaigns   Campaign[]
  regions     GeoRegion[]
  reports     FieldReport[]
  socialPosts SocialPost[]
  insights    AiInsight[]
  alerts      Alert[]
  contacts    Contact[]
  auditLogs   AuditLog[]
  parties     PoliticalParty[]
  voterImports VoterRegisterImport[]
}

model User {
  id              String      @id @default(cuid())
  tenantId        String
  email           String
  name            String
  passwordHash    String
  status          UserStatus  @default(ACTIVE)
  mfaEnabled      Boolean     @default(false)
  lastSeenAt      DateTime?
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships     Membership[]
  fieldReports    FieldReport[] @relation("ReporterReports")
  sessions        UserSession[]
  auditLogs       AuditLog[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId, status])
}

model Role {
  id          String        @id @default(cuid())
  name        String
  description String
  permissions String[]
  memberships Membership[]
  createdAt   DateTime      @default(now())

  @@unique([name])
}

model Membership {
  id         String    @id @default(cuid())
  userId     String
  roleId     String
  campaignId String?
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role      @relation(fields: [roleId], references: [id])
  campaign   Campaign? @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, campaignId])
}

model Campaign {
  id          String         @id @default(cuid())
  tenantId    String
  name        String
  candidate   String
  office      String
  status      CampaignStatus @default(PLANNING)
  electionDate DateTime
  strategy    Json           @default("{}")
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships Membership[]
  fieldReports FieldReport[]
  surveys     Survey[]
  events      CampaignEvent[]
  resources   ResourceDeployment[]
  partyId     String?
  party       PoliticalParty? @relation(fields: [partyId], references: [id])
  visits      CandidateVisit[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId, status])
}

model GeoRegion {
  id              String      @id @default(cuid())
  tenantId        String
  parentId        String?
  code            String
  name            String
  level           GeoLevel
  population      Int?
  registeredVoters Int?
  properties      Json        @default("{}")
  centroidLat     Float?
  centroidLng     Float?
  geojson         Json?
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent          GeoRegion?  @relation("GeoHierarchy", fields: [parentId], references: [id])
  children        GeoRegion[] @relation("GeoHierarchy")
  fieldReports    FieldReport[]
  socialPosts     SocialPost[]
  alerts          Alert[]
  contacts        Contact[]
  pollingStations PollingStation[]
  visits          CandidateVisit[]

  @@unique([tenantId, code])
  @@index([tenantId, level])
}

model PollingStation {
  id          String    @id @default(cuid())
  tenantId    String
  regionId    String
  code        String
  name        String
  latitude    Float
  longitude   Float
  registeredVoters Int
  turnoutProjection Float @default(0)
  supportProjection Float @default(0)
  region      GeoRegion @relation(fields: [regionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([regionId])
}

model PoliticalParty {
  id          String     @id @default(cuid())
  tenantId    String
  name        String
  abbreviation String
  color       String
  ideology    String
  strongholds String[]
  influenceScore Float  @default(0)
  sentimentScore Float  @default(0)
  riskFactors String[]
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaigns   Campaign[]
  createdAt   DateTime  @default(now())

  @@unique([tenantId, abbreviation])
}

model CandidateVisit {
  id          String    @id @default(cuid())
  campaignId  String
  regionId    String?
  title       String
  visitType   String
  latitude    Float
  longitude   Float
  attendance  Int       @default(0)
  sentimentScore Float  @default(0)
  occurredAt  DateTime
  notes       String?
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  region      GeoRegion? @relation(fields: [regionId], references: [id])

  @@index([campaignId, occurredAt])
  @@index([regionId])
}

model VoterRegisterImport {
  id          String    @id @default(cuid())
  tenantId    String
  sourceName  String
  sourceType  String
  fileName    String
  status      String
  rowsParsed  Int       @default(0)
  votersTotal Int       @default(0)
  errors      Json      @default("[]")
  importedAt  DateTime  @default(now())
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, importedAt])
}

model FieldReport {
  id          String          @id @default(cuid())
  tenantId    String
  campaignId  String
  reporterId  String
  regionId    String?
  type        FieldReportType
  title       String
  body        String
  latitude    Float?
  longitude   Float?
  occurredAt  DateTime
  offlineId   String?
  confidence  Float           @default(0.75)
  sentiment   SentimentLabel  @default(NEUTRAL)
  attachments Json            @default("[]")
  metadata    Json            @default("{}")
  syncedAt    DateTime?
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign    Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  reporter    User            @relation("ReporterReports", fields: [reporterId], references: [id])
  region      GeoRegion?      @relation(fields: [regionId], references: [id])
  createdAt   DateTime        @default(now())

  @@unique([tenantId, offlineId])
  @@index([tenantId, campaignId, occurredAt])
  @@index([regionId, type])
}

model SocialPost {
  id             String         @id @default(cuid())
  tenantId       String
  regionId       String?
  source         String
  externalId     String
  authorHandle   String
  authorName     String?
  text           String
  url            String?
  language       String         @default("en")
  sentiment      SentimentLabel @default(NEUTRAL)
  sentimentScore Float          @default(0)
  engagement     Int            @default(0)
  topics         String[]
  hashtags       String[]
  detectedAt     DateTime       @default(now())
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  region         GeoRegion?     @relation(fields: [regionId], references: [id])

  @@unique([tenantId, source, externalId])
  @@index([tenantId, detectedAt])
  @@index([regionId, sentiment])
}

model NarrativeCluster {
  id          String         @id @default(cuid())
  tenantId    String
  campaignId  String?
  name        String
  summary     String
  sentiment   SentimentLabel
  velocity    Float
  reach       Int
  riskScore   Float
  topics      String[]
  regions     String[]
  createdAt   DateTime       @default(now())

  @@index([tenantId, riskScore])
}

model AiInsight {
  id          String      @id @default(cuid())
  tenantId    String
  campaignId  String?
  type        InsightType
  title       String
  summary     String
  recommendation String
  confidence  Float
  evidence    Json        @default("[]")
  priority    Int         @default(3)
  generatedAt DateTime    @default(now())
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, generatedAt])
}

model Alert {
  id          String        @id @default(cuid())
  tenantId    String
  regionId    String?
  severity    AlertSeverity
  status      AlertStatus   @default(OPEN)
  title       String
  message     String
  channels    String[]
  ruleKey     String
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now())
  resolvedAt  DateTime?
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  region      GeoRegion?    @relation(fields: [regionId], references: [id])

  @@index([tenantId, status, severity])
}

model Survey {
  id          String    @id @default(cuid())
  campaignId  String
  name        String
  description String
  schema      Json
  active      Boolean   @default(true)
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  responses   SurveyResponse[]
  publicLinks PublicSurveyLink[]
  createdAt   DateTime  @default(now())
}

model PublicSurveyLink {
  id          String   @id @default(cuid())
  surveyId    String
  slug        String   @unique
  title       String
  targetRegionCode String?
  targetSegment String?
  expiresAt   DateTime?
  active      Boolean  @default(true)
  scans       Int      @default(0)
  submissions Int      @default(0)
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model SurveyResponse {
  id          String   @id @default(cuid())
  surveyId    String
  contactId   String?
  regionId    String?
  answers     Json
  demographic Json     @default("{}")
  sentimentScore Float @default(0)
  submittedAt DateTime @default(now())
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
}

model Contact {
  id          String      @id @default(cuid())
  tenantId    String
  regionId    String?
  type        ContactType
  name        String
  phone       String?
  email       String?
  tags        String[]
  supportScore Float      @default(0)
  issueInterests String[]
  communicationHistory Json @default("[]")
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  region      GeoRegion?  @relation(fields: [regionId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([tenantId, type])
  @@index([regionId, supportScore])
}

model CampaignEvent {
  id          String    @id @default(cuid())
  campaignId  String
  name        String
  type        String
  regionCode  String
  attendance  Int       @default(0)
  sentimentScore Float  @default(0)
  occurredAt  DateTime
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model ResourceDeployment {
  id          String    @id @default(cuid())
  campaignId  String
  regionCode  String
  resourceType String
  quantity    Int
  status      String
  deployedAt  DateTime
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  deviceName  String
  ipAddress   String
  userAgent   String
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorId     String?
  action      String
  entityType  String
  entityId    String
  before      Json?
  after       Json?
  ipAddress   String?
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor       User?    @relation(fields: [actorId], references: [id])

  @@index([tenantId, createdAt])
}
